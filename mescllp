<script>
// ── Init Swiper
const heroSwiper = new Swiper('.hero-swiper', {
  loop: true,
  autoplay: { delay: 4000, disableOnInteraction: false },
  pagination: { el: '.swiper-pagination', clickable: true },
  navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
  effect: 'fade',
  fadeEffect: { crossFade: true },
});

// ── Category switcher
function switchCat(id, btn) {
  document.querySelectorAll('.prod-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.cat-btn').forEach(b => {
    b.classList.remove('active');
    b.classList.remove('cat-btn-active');
    b.style.background = '';
    b.style.color = '';
    b.style.fontWeight = '';
    const pill = b.querySelector('.cat-pill');
    if (pill) { pill.style.background = 'rgba(255,255,255,0.1)'; pill.style.color = 'rgba(255,255,255,0.6)'; }
  });

  const panel = document.getElementById('panel-' + id);
  if (panel) panel.classList.add('active');
  if (btn) {
    btn.classList.add('active');
    btn.style.background = 'rgba(255,255,255,0.10)';
    btn.style.color = '#fff';
    btn.style.fontWeight = '700';
    const pill = btn.querySelector('.cat-pill');
    if (pill) { pill.style.background = '#F05A1A'; pill.style.color = '#fff'; }
  }

  // Auto-activate first brand tab
  const firstBrandTab = panel?.querySelector('.brand-tab');
  const firstBrandPanel = panel?.querySelector('.brand-prod-panel');
  panel?.querySelectorAll('.brand-tab').forEach(t => { t.classList.remove('active-brand'); t.style.color = ''; t.style.borderBottomColor = 'transparent'; });
  panel?.querySelectorAll('.brand-prod-panel').forEach(p => p.classList.remove('active'));
  if (firstBrandTab) { firstBrandTab.classList.add('active-brand'); firstBrandTab.style.color = '#1A3A6B'; firstBrandTab.style.borderBottomColor = '#F05A1A'; }
  if (firstBrandPanel) firstBrandPanel.classList.add('active');
}

// ── Brand tab switcher
function switchBrand(brandPanelId, btn, catPanelId) {
  const catPanel = document.getElementById(catPanelId);
  catPanel?.querySelectorAll('.brand-tab').forEach(t => { t.classList.remove('active-brand'); t.style.color = ''; t.style.borderBottomColor = 'transparent'; });
  catPanel?.querySelectorAll('.brand-prod-panel').forEach(p => p.classList.remove('active'));
  if (btn) { btn.classList.add('active-brand'); btn.style.color = '#1A3A6B'; btn.style.borderBottomColor = '#F05A1A'; }
  const bp = document.getElementById(brandPanelId);
  if (bp) bp.classList.add('active');
}

// Init active states on load
document.addEventListener('DOMContentLoaded', () => {
  const activeBtn = document.querySelector('.cat-btn.active');
  if (activeBtn) {
    activeBtn.style.background = 'rgba(255,255,255,0.10)';
    activeBtn.style.color = '#fff';
    activeBtn.style.fontWeight = '700';
    const pill = activeBtn.querySelector('.cat-pill');
    if (pill) { pill.style.background = '#F05A1A'; pill.style.color = '#fff'; }
  }
  document.querySelectorAll('.brand-tab.active-brand').forEach(t => {
    t.style.color = '#1A3A6B';
    t.style.borderBottomColor = '#F05A1A';
  });
  // FAQ — show first answer
  const firstFaq = document.querySelector('.faq-item.open .faq-a');
  if (firstFaq) firstFaq.classList.remove('hidden');
});

// ── FAQ toggle
function toggleFaq(btn) {
  const item = btn.parentElement;
  const answer = item.querySelector('.faq-a');
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => {
    i.classList.remove('open');
    i.querySelector('.faq-chevron').style.transform = '';
    const a = i.querySelector('.faq-a');
    if (a) a.classList.add('hidden');
  });
  if (!wasOpen) {
    item.classList.add('open');
    btn.querySelector('.faq-chevron').style.transform = 'rotate(180deg)';
    if (answer) answer.classList.remove('hidden');
  }
}

// ── Enquiry form
document.getElementById('enquiry-form')?.addEventListener('submit', function(e) {
  e.preventDefault();
  const data = new FormData(this);
  const name = data.get('name');
  const phone = data.get('phone');
  const req = data.get('requirement');
  const area = data.get('area') || 'Not specified';
  const msg = data.get('message') || '';
  const wa = `https://wa.me/917838493878?text=Hi%2C%20I%20am%20${encodeURIComponent(name)}%20(${encodeURIComponent(phone)}).%20I%20need%20${encodeURIComponent(req)}%20in%20${encodeURIComponent(area)}.%20${encodeURIComponent(msg)}`;
  window.open(wa, '_blank');
  this.reset();
});
</script>
